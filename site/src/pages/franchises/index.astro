---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { directusFetchItems } from "../../lib/directus";
import { sortByTitle } from "../../lib/list-format";

const [franchisesRaw, allFranchiseGames] = await Promise.all([
  directusFetchItems("franchises", {
    fields: ["id", "title", "slug", "description"],
    filter: { status: { _eq: "published" } },
    limit: -1,
  }),
  directusFetchItems("franchise_games", {
    fields: ["franchise_id"],
    limit: -1,
  }),
]);
const franchises = sortByTitle(franchisesRaw);
const countsByFranchise = new Map<number, number>();
for (const entry of allFranchiseGames ?? []) {
  const id = entry?.franchise_id;
  if (typeof id === "number") countsByFranchise.set(id, (countsByFranchise.get(id) ?? 0) + 1);
}
---

<BaseLayout title="Franchises">
  <div slot="head">
    <style>
      main{padding:24px;}
      .list{max-width:980px;margin:0 auto;}
      .item{border:1px solid #222;border-radius:10px;padding:16px;margin:12px 0;background:#111;}
      .desc{opacity:.85;margin-top:.4rem;}
      .item a{color:#9aa6ff;}
      .item a:visited{color:#9aa6ff;}
    </style>
  </div>
  <main>
    <div class="list">
      <h1>Franchises</h1>
      {franchises.length === 0 ? (
        <p>No franchises yet.</p>
      ) : (
        franchises.map((f) => (
          <div class="item">
            <a href={`/franchises/${f.slug}/index.html`}>{f.title}</a>
            <span style="opacity:.7;"> ({countsByFranchise.get(f.id) ?? 0})</span>
            {f.description ? <div class="desc">{f.description}</div> : null}
          </div>
        ))
      )}
    </div>
  </main>
</BaseLayout>
