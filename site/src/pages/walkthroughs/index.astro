---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WalkthroughGameList from "../../components/WalkthroughGameList.astro";
import { directusFetchItems } from "../../lib/directus";
import { GAME_THUMB_FIELDS } from "../../lib/game-fields";
import { sortByTitle } from "../../lib/list-format";

const walkthroughLinkRows = await directusFetchItems("games_links", {
  fields: ["games_id"],
  filter: { kind: { _in: ["walkthrough", "text-note"] } },
  limit: -1,
});
const gameIdsWithWalkthrough = [...new Set(
  (walkthroughLinkRows ?? []).map((r) => r.games_id).filter((id) => typeof id === "number"),
)];

const games = gameIdsWithWalkthrough.length
  ? sortByTitle(await directusFetchItems("games", {
      fields: GAME_THUMB_FIELDS,
      filter: { id: { _in: gameIdsWithWalkthrough } },
      limit: -1,
    }))
  : [];

---

<BaseLayout title="Walkthroughs">
  <div slot="head">
    <style>
      main{max-width:980px;margin:0 auto;padding:24px;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
    </style>
  </div>
  <main>
      <div class="panel">
        <h1>Walkthroughs</h1>
        {games.length === 0 ? (
          <p>No walkthroughs yet.</p>
        ) : (
          <WalkthroughGameList games={games} />
        )}
      </div>
  </main>
</BaseLayout>
