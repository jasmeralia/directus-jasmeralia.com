---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { directusFetchItems, fileUrl, isFamilySharingDisabled } from '../../lib/directus';
import { formatDate } from "../../lib/date";
import { primaryDownloadLink, walkthroughLinks, getLinkMeta } from "../../lib/download-link";

export async function getStaticPaths() {
  const games = await directusFetchItems('games', {
    fields: ['slug'],
    limit: -1,
    sort: ['sort', 'title'],
  });

  return games
    .filter((g) => !!g.slug)
    .map((g) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;

const games = await directusFetchItems('games', {
  fields: [
    'id',
    'title',
    'slug',
    'release_year',
    'family_sharing',
    'gamestorylog_url',
    'player_status',
    'game_status',
    'cover_image.id',
    'cover_image.filename_disk',
    'genres.id',
    'genres.genres_id.id',
    'genres.genres_id.name',
    'genres.genres_id.slug',
    'engines.id',
    'engines.engines_id.id',
    'engines.engines_id.title',
    'engines.engines_id.slug',
    'developers.id',
    'developers.developers_id.id',
    'developers.developers_id.name',
    'developers.developers_id.slug',
    'links.id',
    'links.url',
    'links.label',
    'links.kind',
    'links.sort',
  ],
  filter: { slug: { _eq: slug } },
  limit: 1,
});

const game = games?.[0];
if (!game) {
  throw new Error(`Game not found for slug: ${slug}`);
}

const cover = fileUrl(game.cover_image);
const labelize = (value) => value ? value.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()) : "";
const tierLabel = (value) => value === "U" ? "Too Early" : (value ?? "");
const genres = (game.genres ?? [])
  .map((genre) => genre?.genres_id)
  .filter((value) => value && value.name && value.slug);
const engines = (game.engines ?? [])
  .map((engine) => engine?.engines_id)
  .filter((value) => value && value.title && value.slug);
const developers = (game.developers ?? [])
  .map((developer) => developer?.developers_id)
  .filter((value) => value && (value.name || value.title) && value.slug)
  .sort((a, b) => (a.name ?? a.title ?? "").localeCompare(b.name ?? b.title ?? "", undefined, { sensitivity: "base" }));
const reviews = await directusFetchItems('reviews', {
  fields: ['id', 'title', 'slug', 'published_at'],
  filter: { status: { _eq: "published" }, game: { _eq: game.id } },
  sort: ['-published_at'],
  limit: 100,
});
const franchiseEntries = await directusFetchItems('franchise_games', {
  fields: ['franchise_id.id', 'franchise_id.title', 'franchise_id.slug'],
  filter: { game_id: { _eq: game.id }, franchise_id: { status: { _eq: "published" } } },
  limit: 50,
});
const franchises = (franchiseEntries ?? [])
  .map((e) => e?.franchise_id)
  .filter((f) => f?.slug && f?.title)
  .sort((a, b) => a.title.localeCompare(b.title, undefined, { sensitivity: "base" }));
const tierEntries = await directusFetchItems('tier_list_games', {
  fields: [
    'id',
    'rating',
    'tier_list_id.id',
    'tier_list_id.title',
    'tier_list_id.slug',
  ],
  filter: { game_id: { _eq: game.id }, tier_list_id: { status: { _eq: "published" } } },
  sort: ['tier_list_id.title'],
  limit: 200,
});
const tierListsMap = new Map();
for (const entry of (tierEntries ?? [])) {
  const list = entry?.tier_list_id;
  if (!list?.slug || !list?.title) continue;
  if (!tierListsMap.has(list.slug)) {
    tierListsMap.set(list.slug, { slug: list.slug, title: list.title, label: entry?.rating ?? "" });
  }
}
const tierLists = Array.from(tierListsMap.values())
  .sort((a, b) => a.title.localeCompare(b.title, undefined, { sensitivity: "base" }));
const downloadLink = primaryDownloadLink(game.links);
const downloadLinkMeta = downloadLink ? getLinkMeta(downloadLink) : null;
const downloadLinkText = downloadLinkMeta
  ? downloadLinkMeta.label === "Download"
    ? downloadLinkMeta.host
      ? `Download (${downloadLinkMeta.host})`
      : "Download"
    : `Download from ${downloadLinkMeta.label}`
  : null;
const walkthroughEntries = walkthroughLinks(game.links).map((link) => {
  const linkMeta = getLinkMeta(link);
  return {
    url: link.url,
    linkMeta,
    linkText:
      linkMeta.label === "Download"
        ? linkMeta.host
          ? `Walkthrough (${linkMeta.host})`
          : "Walkthrough"
        : `Walkthrough on ${linkMeta.label}`,
  };
});
const reviewed = reviews.length > 0;
const sTier = tierLists.some((tier) => tier.label === "S");
const completed = game?.player_status === "completed";
const didNotFinish = game?.player_status === "did_not_finish";
const inProgress = game?.player_status === "in_progress";
const waitingForUpdate = game?.player_status === "waiting_for_update";
const hasWalkthrough = walkthroughEntries.length > 0;
const statusColor = completed
  ? "#c0c0c0"
  : didNotFinish
    ? "#d14b4b"
    : inProgress
      ? "#70b7ff"
      : waitingForUpdate
        ? "#1f6b2b"
        : null;
const innerBorderColor = hasWalkthrough
  ? "#8c58ff"
  : statusColor ?? (!reviewed && !sTier ? "#2b2b2b" : "transparent");
const statusRingColor = hasWalkthrough ? statusColor : null;
const coverStackStyle = [
  `--ring-rainbow-pad:${sTier ? 2 : 0}px`,
  `--ring-gold-pad:${reviewed ? 2 : 0}px`,
  `--ring-status-pad:${statusRingColor ? 2 : 0}px`,
  `--ring-status-color:${statusRingColor ?? "transparent"}`,
  `--gap-rainbow-pad:${sTier && (reviewed || hasWalkthrough || statusColor) ? 1 : 0}px`,
  `--gap-gold-pad:${reviewed && (hasWalkthrough || statusColor) ? 1 : 0}px`,
  `--gap-status-pad:${statusRingColor ? 1 : 0}px`,
  `--inner-border:${innerBorderColor}`,
].join(";");
---

<BaseLayout title={`Games | ${game.title}`}>
  <div slot="head">
    <style>
      .container { max-width: 1100px; margin: 0 auto; padding: 1.25rem; }
      .header { display: flex; gap: 1rem; align-items: center; }
      .cover-stack,.cover-ring-rainbow,.cover-gap-rainbow,.cover-ring-gold,.cover-gap-gold,.cover-ring-status,.cover-gap-status,.cover-card{border-radius:10px;}
      .cover-ring-rainbow,.cover-gap-rainbow,.cover-ring-gold,.cover-gap-gold,.cover-ring-status,.cover-gap-status{padding:0;background:transparent;}
      .cover-ring-rainbow{
        padding:var(--ring-rainbow-pad,0);
        background:linear-gradient(135deg,#ff5f6d,#ffc371,#fff45f,#6dff9a,#5fe2ff,#8c7bff,#ff6ddf);
        box-shadow:0 0 0 1px rgba(255,255,255,.06), 0 0 14px rgba(255,180,80,.22);
      }
      .cover-gap-rainbow{padding:var(--gap-rainbow-pad,0);background:#000;}
      .cover-ring-gold{padding:var(--ring-gold-pad,0);background:#d3a43b;}
      .cover-gap-gold{padding:var(--gap-gold-pad,0);background:#000;}
      .cover-ring-status{padding:var(--ring-status-pad,0);background:var(--ring-status-color,transparent);}
      .cover-gap-status{padding:var(--gap-status-pad,0);background:#000;}
      .cover-card{width:320px;background:#000;border:2px solid var(--inner-border,#2b2b2b);padding:10px;}
      .cover-card img { width: 100%; height: auto; object-fit: contain; display: block; }
      .meta { opacity: 0.9; }
      .section{margin-top:1.5rem;}
      .label{opacity:.7;font-size:.85rem;text-transform:uppercase;letter-spacing:.08em;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
      .meta a{color:#9aa6ff;}
      .meta a:visited{color:#9aa6ff;}
      .download-link{display:inline-flex;align-items:center;gap:.45rem;}
      .download-link img{width:1rem;height:1rem;display:block;}
      .download-link .platform-icon{filter:brightness(0) saturate(100%) invert(67%) sepia(11%) saturate(1832%) hue-rotate(194deg) brightness(97%) contrast(96%);}
      .download-link .gsl-icon{filter:none;}
    </style>
  </div>
  <main class="container" data-pagefind-body data-pagefind-filter="type:game">
      <section class="header">
        <div class="cover-stack" style={coverStackStyle}>
          <div class="cover-ring-rainbow">
            <div class="cover-gap-rainbow">
              <div class="cover-ring-gold">
                <div class="cover-gap-gold">
                  <div class="cover-ring-status">
                    <div class="cover-gap-status">
                      <div class="cover-card">
                        {cover ? <img src={cover} alt={game.title} loading="lazy" data-pagefind-meta="image[src]" /> : null}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h1 data-pagefind-meta="title">{game.title}</h1>
                    {downloadLink || game.gamestorylog_url ? (
            <div class="meta">
              {downloadLink ? (
                <div>
                  <a class="download-link" href={downloadLink.url} rel="noopener noreferrer" target="_blank">
                    {downloadLinkMeta!.icon ? (
                      <img class="platform-icon" src={downloadLinkMeta!.icon} alt="" aria-hidden="true" loading="lazy" />
                    ) : null}
                    <span>{downloadLinkText}</span>
                  </a>
                </div>
              ) : null}
              {game.gamestorylog_url ? (
                <div>
                  <a class="download-link" href={game.gamestorylog_url} rel="noopener noreferrer" target="_blank">
                    <img class="gsl-icon" src="/icons/gamestorylog.png" alt="" aria-hidden="true" loading="lazy" />
                    <span>View on GameStoryLog</span>
                  </a>
                </div>
              ) : null}
            </div>
          ) : null}
        </div>
      </section>

      <div class="section panel">
        <div class="label">Details</div>
        <ul>
          {developers.length ? (
            <li>
              <strong>Developers:</strong> {developers.map((developer, index) => (
                <span>
                  <a href={`/developers/${developer.slug}/index.html`}>{developer.name ?? developer.title}</a>
                  {index < developers.length - 1 ? ", " : ""}
                </span>
              ))}
            </li>
          ) : null}
          {engines.length ? (
            <li>
              <strong>Engines:</strong> {engines.map((engine, index) => (
                <span>
                  <a href={`/engines/${engine.slug}/index.html`}>{engine.title}</a>
                  {index < engines.length - 1 ? ", " : ""}
                </span>
              ))}
            </li>
          ) : null}
          {game.game_status ? (
            <li>
              <strong>Game status:</strong> <a href={`/game_statuses/${game.game_status}/index.html`}>{labelize(game.game_status)}</a>
            </li>
          ) : null}
          {genres.length ? (
            <li>
              <strong>Genres:</strong> {genres.map((genre, index) => (
                <span>
                  <a href={`/genres/${genre.slug}/index.html`}>{genre.name}</a>
                  {index < genres.length - 1 ? ", " : ""}
                </span>
              ))}
            </li>
          ) : null}
          {game.player_status ? (
            <li>
              <strong>Player status:</strong> <a href={`/played_statuses/${game.player_status}/index.html`}>{labelize(game.player_status)}</a>
            </li>
          ) : null}
          {game.release_year ? (
            <li>
              <strong>Release year:</strong>{" "}
              <a href={`/releases/${game.release_year}/index.html`}>{game.release_year}</a>
            </li>
          ) : null}
          {isFamilySharingDisabled(game) ? (
            <li><strong>Steam Family Sharing is NOT supported for this title.</strong></li>
          ) : null}
          {franchises.length ? (
            <li>
              <strong>Franchises:</strong> {franchises.map((f, index) => (
                <span>
                  <a href={`/franchises/${f.slug}/index.html`}>{f.title}</a>
                  {index < franchises.length - 1 ? ", " : ""}
                </span>
              ))}
            </li>
          ) : null}
          {tierLists.length ? (
            <li>
              <strong>Tier lists:</strong> {tierLists.map((tier, index) => (
                <span>
                  <a href={`/tiers/${tier.slug}/index.html`}>{tier.title}</a>
                  {tier.label ? ` (${tierLabel(tier.label)})` : ""}
                  {index < tierLists.length - 1 ? ", " : ""}
                </span>
              ))}
            </li>
          ) : null}
          {walkthroughEntries.length > 0 ? (
            <li>
              <strong>Walkthrough:</strong>{" "}
              {walkthroughEntries.map((entry, index) => (
                <>
                  {index > 0 ? <span> | </span> : null}
                  <a class="download-link" href={entry.url} rel="noopener noreferrer" target="_blank">
                    {entry.linkMeta.icon ? (
                      <img class="platform-icon" src={entry.linkMeta.icon} alt="" aria-hidden="true" loading="lazy" />
                    ) : null}
                    <span>{entry.linkText}</span>
                  </a>
                </>
              ))}
            </li>
          ) : null}
        </ul>
      </div>

      {reviews.length ? (
        <div class="section panel">
          <div class="label">Reviews</div>
          <ul>
            {reviews.map((review) => (
              <li>
                <a href={`/reviews/${review.slug}/index.html`}>{review.title}</a>
                {review.published_at ? (
                  <span style="opacity:.7;margin-left:.5rem;">({formatDate(review.published_at)})</span>
                ) : null}
              </li>
            ))}
          </ul>
        </div>
      ) : null}
  </main>
</BaseLayout>
