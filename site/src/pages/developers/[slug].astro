---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CsvHeader from "../../components/CsvHeader.astro";
import ThumbnailBorderLegend from "../../components/ThumbnailBorderLegend.astro";
import GameThumbCard from "../../components/GameThumbCard.astro";
import { renderMarkdown } from "../../lib/markdown";
import { directusFetchItems, fileUrl, getSTierGameIds } from "../../lib/directus";
import { csvDataUri, gamesToCsv } from "../../lib/csv";
import { formatDate } from "../../lib/date";
import { GAME_THUMB_FIELDS } from "../../lib/game-fields";
import { sortByTitle } from "../../lib/list-format";
import { getDeveloperLinkMeta } from "../../lib/download-link";

export async function getStaticPaths() {
  const developers = await directusFetchItems("developers", {
    fields: ["slug"],
    limit: -1,
  });

  return developers
    .filter((developer) => !!developer.slug)
    .map((developer) => ({ params: { slug: developer.slug } }))
    .concat([{ params: { slug: "unknown" } }]);
}

const { slug } = Astro.params;
const isUnknown = slug === "unknown";

let title = "Unknown";
let developer = null;
let games;
let reviews = [];

if (isUnknown) {
  const allGames = await directusFetchItems("games", {
    fields: [...GAME_THUMB_FIELDS, "developers.id"],
    limit: -1,
  });
  games = allGames.filter((game) => (game.developers ?? []).length === 0);
} else {
  const developers = await directusFetchItems("developers", {
    fields: ["*", "logo.id", "logo.filename_disk", "links.id", "links.url", "links.label", "links.kind"],
    filter: { slug: { _eq: slug } },
    limit: 1,
  });

  developer = developers?.[0];
  if (!developer) {
    throw new Error(`Developer not found for slug: ${slug}`);
  }
  title = developer.name ?? developer.title ?? title;

  games = await directusFetchItems("games", {
    fields: GAME_THUMB_FIELDS,
    filter: { developers: { developers_id: { slug: { _eq: slug } } } },
    limit: -1,
  });
}

const logo = developer?.logo ? fileUrl(developer.logo) : null;
games = sortByTitle(games);
const gameIds = games.map((game) => game.id).filter((id) => typeof id === "number");
if (gameIds.length) {
  reviews = await directusFetchItems("reviews", {
    fields: ["id", "title", "slug", "published_at", "rating", "game.id"],
    filter: { status: { _eq: "published" }, game: { _in: gameIds } },
    sort: ["-published_at", "title"],
    limit: -1,
  });
}
const sTierGameIds = await getSTierGameIds(gameIds);
const reviewedGameIds = new Set(
  (reviews ?? [])
    .map((review) => review?.game?.id)
    .filter((id) => typeof id === "number"),
);
const excludedFields = new Set([
  "id",
  "slug",
  "name",
  "title",
  "logo",
  "links",
  "status",
  "sort",
  "date_created",
  "date_updated",
  "user_created",
  "user_updated",
]);
const developerLinks = (developer?.links ?? [])
  .filter((link) => link?.url && link?.kind)
  .sort((a, b) => {
    const kindOrder = { patreon: 0, subscribestar: 1, discord: 2, itch: 3, website: 4, other: 5 };
    return (kindOrder[a.kind] ?? 9) - (kindOrder[b.kind] ?? 9);
  });
const markdownFields = ["description", "body", "notes"];
const markdownContent = markdownFields
  .map((key) => developer?.[key])
  .find((value) => typeof value === "string" && value.trim());
const detailEntries = developer
  ? Object.entries(developer)
      .filter(([, value]) => value !== null && value !== undefined)
      .filter(([key]) => !excludedFields.has(key))
      .filter(([key]) => !markdownFields.includes(key))
      .filter(([, value]) => ["string", "number", "boolean"].includes(typeof value))
  : [];
const formatLabel = (value) =>
  value.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
const isUrl = (value) => typeof value === "string" && /^https?:\/\//.test(value);

const csvName = `developer-${slug}.csv`;
const csvHref = csvDataUri(gamesToCsv(games));
---

<BaseLayout title={`Developers | ${title}`}>
  <div slot="head">
    <style>
      main{padding:24px;}
      ul{list-style:disc;padding-left:20px;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;margin-bottom:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
      .label{opacity:.7;font-size:.85rem;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;}
      .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;}
      .logo{max-width:200px;margin:12px 0;}
      .logo img{width:100%;height:auto;display:block;}
      .dev-link{display:inline-flex;align-items:center;gap:.4rem;color:#9aa6ff;text-decoration:none;}
      .dev-link:hover{text-decoration:underline;}
      .dev-link img{width:.9rem;height:.9rem;display:block;filter:brightness(0) saturate(100%) invert(67%) sepia(11%) saturate(1832%) hue-rotate(194deg) brightness(97%) contrast(96%);}
      .dev-link-url{font-size:.82rem;color:#5f667a;word-break:break-all;}
    </style>
  </div>
  <main>
    <CsvHeader title={title} count={games.length} csvHref={csvHref} csvName={csvName} />
    {logo ? (
      <div class="logo">
        <img src={logo} alt={`${title} logo`} loading="lazy" />
      </div>
    ) : null}
    {developerLinks.length > 0 ? (
      <div class="panel">
        <div class="label">Links</div>
        <ul>
          {developerLinks.map((link) => {
            const meta = getDeveloperLinkMeta(link);
            return (
              <li>
                <a class="dev-link" href={link.url} target="_blank" rel="noopener noreferrer">
                  {meta.icon ? <img src={meta.icon} alt="" aria-hidden="true" loading="lazy" /> : null}
                  <span>{meta.label}</span>
                </a>
                {" "}<span class="dev-link-url">{link.url}</span>
              </li>
            );
          })}
        </ul>
      </div>
    ) : null}
    {detailEntries.length ? (
      <div class="panel">
        <div class="label">Details</div>
        <ul>
          {detailEntries.map(([key, value]) => (
            <li>
              <strong>{formatLabel(key)}:</strong>{" "}
              {isUrl(value) ? (
                <a href={value} target="_blank" rel="noopener noreferrer">{value}</a>
              ) : String(value)}
            </li>
          ))}
        </ul>
      </div>
    ) : null}
    {markdownContent ? (
      <div class="panel" set:html={renderMarkdown(markdownContent)} />
    ) : null}
    {isUnknown && games.length === 0 ? (
      <div class="panel">
        <p>No games have an unknown developer.</p>
      </div>
    ) : (
      <>
        <div class="panel">
          <div class="label">Games</div>
          <ThumbnailBorderLegend />
    {games.length === 0 ? (
            <p>No games found for this developer.</p>
          ) : (
            <div class="grid">
              {games.map((game) => {
                const reviewed = reviewedGameIds.has(game.id);
                const sTier = sTierGameIds.has(game.id);
                return (
                  <GameThumbCard game={game} reviewed={reviewed} sTier={sTier} />
                );
              })}
            </div>
          )}
        </div>
        <div class="panel">
          <div class="label">Reviews</div>
          {reviews.length === 0 ? (
            <p>No reviews for games from this developer yet.</p>
          ) : (
            <ul>
              {reviews.map((review) => (
                <li>
                  <a href={`/reviews/${review.slug}/index.html`}>{review.title}</a>
                  {typeof review.rating === "number" ? <span> (Rating: {review.rating}/10)</span> : null}
                  {review.published_at ? <span style="opacity:.6;margin-left:.5rem;">Published: {formatDate(review.published_at)}</span> : null}
                </li>
              ))}
            </ul>
          )}
        </div>
      </>
    )}
  </main>
</BaseLayout>
