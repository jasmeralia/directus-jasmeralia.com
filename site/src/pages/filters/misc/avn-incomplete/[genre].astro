---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import CsvHeader from "../../../../components/CsvHeader.astro";
import ThumbnailBorderLegend from "../../../../components/ThumbnailBorderLegend.astro";
import GameThumbCard from "../../../../components/GameThumbCard.astro";
import { directusFetchItems, getSTierGameIds } from "../../../../lib/directus";
import { csvDataUri, gamesToCsv } from "../../../../lib/csv";
import { GAME_THUMB_FIELDS } from "../../../../lib/game-fields";
import { sortByTitle } from "../../../../lib/list-format";

const INCOMPLETE_STATUSES = ["not_started", "in_progress", "on_hold", "waiting_for_update"];

export async function getStaticPaths() {
  const games = await directusFetchItems("games", {
    fields: ["id", "player_status", "genres.genres_id.slug"],
    limit: -1,
  });

  const genreSlugs = new Set<string>();
  for (const game of games ?? []) {
    if (!game.player_status || !new Set(["not_started", "in_progress", "on_hold", "waiting_for_update"]).has(game.player_status)) continue;
    const slugs = ((game.genres ?? []) as Array<{ genres_id?: { slug?: string } }>)
      .map((entry) => entry?.genres_id?.slug)
      .filter(Boolean) as string[];
    if (!slugs.includes("avn")) continue;
    for (const slug of slugs) {
      if (slug !== "avn") genreSlugs.add(slug);
    }
  }

  return Array.from(genreSlugs).map((genre) => ({ params: { genre } }));
}

const { genre } = Astro.params;

const genreRecords = await directusFetchItems("genres", {
  fields: ["slug", "name"],
  filter: { slug: { _eq: genre } },
  limit: 1,
});
const genreLabel = genreRecords?.[0]?.name ?? genre;

const avnIncompleteGames = sortByTitle(await directusFetchItems("games", {
  fields: GAME_THUMB_FIELDS,
  filter: {
    genres: { genres_id: { slug: { _eq: "avn" } } },
    player_status: { _in: INCOMPLETE_STATUSES },
  },
  limit: -1,
}));

const filteredGames = (avnIncompleteGames ?? []).filter(
  (game) => (game?.genres ?? []).some((entry: { genres_id?: { slug?: string } }) => entry?.genres_id?.slug === genre),
);

const gameIds = filteredGames.map((game) => game.id).filter((id) => typeof id === "number");
const sTierGameIds = await getSTierGameIds(gameIds);
const reviewedGameIds = new Set<number>();
if (gameIds.length) {
  const reviews = await directusFetchItems("reviews", {
    fields: ["game.id"],
    filter: { status: { _eq: "published" }, game: { _in: gameIds } },
    limit: -1,
  });
  for (const review of reviews ?? []) {
    const id = review?.game?.id;
    if (typeof id === "number") reviewedGameIds.add(id);
  }
}

const csvName = `avn-incomplete-${genre}.csv`;
const csvHref = csvDataUri(gamesToCsv(filteredGames));
---

<BaseLayout title={`Filters | AVN + ${genreLabel} + Incomplete`}>
  <div slot="head">
    <style>
      main{padding:2rem;}
      .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;margin-bottom:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
    </style>
  </div>
  <main>
    <div class="panel">
      <CsvHeader title={`AVN + ${genreLabel} + Incomplete`} count={filteredGames.length} csvHref={csvHref} csvName={csvName} />
      <p>AVN games tagged as <strong>{genreLabel}</strong> with an incomplete played status (not started, in progress, on hold, or waiting for update).</p>
    </div>
    <ThumbnailBorderLegend />
    {filteredGames.length === 0 ? (
      <p>No games found for this combination.</p>
    ) : (
      <div class="grid">
        {filteredGames.map((game) => {
          const reviewed = reviewedGameIds.has(game.id);
          const sTier = sTierGameIds.has(game.id);
          return <GameThumbCard game={game} reviewed={reviewed} sTier={sTier} />;
        })}
      </div>
    )}
  </main>
</BaseLayout>
