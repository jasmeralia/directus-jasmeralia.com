---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import CsvHeader from "../../../../components/CsvHeader.astro";
import WalkthroughGameList from "../../../../components/WalkthroughGameList.astro";
import { directusFetchItems } from "../../../../lib/directus";
import { csvDataUri, gamesToCsv } from "../../../../lib/csv";
import { GAME_THUMB_FIELDS } from "../../../../lib/game-fields";
import { sortByTitle } from "../../../../lib/list-format";
import {
  WALKTHROUGH_KIND_LABEL,
  WALKTHROUGH_KINDS,
  type WalkthroughKind,
} from "../../../../lib/walkthrough-link";
import { getUrlPlatform, walkthroughLinks, walkthroughTextNotes } from "../../../../lib/download-link";

export async function getStaticPaths() {
  return WALKTHROUGH_KINDS.map((kind) => ({ params: { kind } }));
}

const { kind } = Astro.params;
if (!WALKTHROUGH_KINDS.includes(kind as WalkthroughKind)) {
  throw new Error(`Unsupported walkthrough filter: ${kind}`);
}

const games = sortByTitle(await directusFetchItems("games", {
  fields: GAME_THUMB_FIELDS,
  limit: -1,
}));
const filteredGames = games.filter((game) => {
  const wtLinks = walkthroughLinks(game?.links);
  const notes   = walkthroughTextNotes(game?.links);
  const hasNone = wtLinks.length === 0 && notes.length === 0;
  if (kind === "none-provided") return hasNone;
  if (hasNone) return false;
  if (kind === "text-note") return notes.length > 0;
  if (wtLinks.length === 0) return false;
  return wtLinks.some((link) => {
    const platform = getUrlPlatform(link.url);
    return kind === "unknown" ? platform === null : platform === kind;
  });
});

const walkthroughLabel = WALKTHROUGH_KIND_LABEL[kind as WalkthroughKind];
const csvName = `walkthrough-url-${kind}.csv`;
const csvHref = csvDataUri(gamesToCsv(filteredGames));
---

<BaseLayout title={`Filters | Walkthrough URL + ${walkthroughLabel}`}>
  <div slot="head">
    <style>
      main{padding:2rem;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;margin-bottom:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
    </style>
  </div>
  <main>
    <div class="panel">
      <CsvHeader title={`Walkthrough URL + ${walkthroughLabel}`} count={filteredGames.length} csvHref={csvHref} csvName={csvName} />
      <p>Games where walkthrough URL classification is {walkthroughLabel}.</p>
    </div>
    {filteredGames.length === 0 ? (
      <p>No games found for this walkthrough category.</p>
    ) : (
      <WalkthroughGameList games={filteredGames} kind={kind as WalkthroughKind} />
    )}
  </main>
</BaseLayout>
