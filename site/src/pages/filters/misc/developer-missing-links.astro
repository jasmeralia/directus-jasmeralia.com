---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { directusFetchItems } from "../../../lib/directus";
import { compareLabels } from "../../../lib/list-format";

const linkRows = await directusFetchItems("developers_links", {
  fields: ["developers_id"],
  limit: -1,
});
const devsWithLinks = new Set(
  (linkRows ?? []).map((r) => r.developers_id).filter((id) => typeof id === "number"),
);

const allDevs = await directusFetchItems("developers", {
  fields: ["id", "name", "slug"],
  filter: { slug: { _neq: "unknown" } },
  limit: -1,
});

const missingDevs = (allDevs ?? [])
  .filter((dev) => !devsWithLinks.has(dev.id))
  .sort((a, b) => compareLabels(a.name ?? a.slug ?? "", b.name ?? b.slug ?? ""));
---

<BaseLayout title="Filters | Developer + Missing Links">
  <div slot="head">
    <style>
      main{max-width:980px;margin:0 auto;padding:24px;}
      .panel{background:#111;border:1px solid #222;border-radius:12px;padding:16px;margin-bottom:16px;}
      .panel a{color:#9aa6ff;}
      .panel a:visited{color:#9aa6ff;}
      ul{list-style:disc;padding-left:20px;}
    </style>
  </div>
  <main>
    <div class="panel">
      <h1>Developer + Missing Links <span style="opacity:.6;font-size:.8em;">({missingDevs.length})</span></h1>
      <p>Developers with no entries in the developer links collection.</p>
    </div>
    {missingDevs.length === 0 ? (
      <div class="panel"><p>All developers have at least one link.</p></div>
    ) : (
      <div class="panel">
        <ul>
          {missingDevs.map((dev) => (
            <li>
              <a href={`/developers/${dev.slug}/index.html`}>{dev.name ?? dev.slug}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </main>
</BaseLayout>
