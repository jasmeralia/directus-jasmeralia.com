---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThumbnailBorderLegend from "../../components/ThumbnailBorderLegend.astro";
import { directusFetchItems, getPublishedTierListBySlug, listPublishedTierListSlugs, fileUrl, TIER_RATING_CONFIG } from "../../lib/directus";
import { walkthroughLinks } from "../../lib/download-link";
import { csvDataUri, tierListToCsv } from "../../lib/csv";
import "../../styles/tierlist.css";

// Static generation: /tiers/<slug> for each published tier list
export async function getStaticPaths() {
  const slugs = await listPublishedTierListSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error("Missing slug param");

const tierList = await getPublishedTierListBySlug(slug);
if (!tierList) return Astro.redirect("/404");

const csvHref = csvDataUri(tierListToCsv(tierList.tier_list_games));
const csvName = `${tierList.slug}.csv`;

const gameIds = (tierList.tier_list_games ?? [])
  .map((entry) => entry?.game_id?.id)
  .filter((id) => typeof id === "number");

const reviewedGameIds = new Set();
if (gameIds.length) {
  const reviews = await directusFetchItems("reviews", {
    fields: ["game.id"],
    filter: { status: { _eq: "published" }, game: { _in: gameIds } },
    limit: -1,
  });
  for (const review of reviews ?? []) {
    const id = review?.game?.id;
    if (typeof id === "number") reviewedGameIds.add(id);
  }
}

// Group games by rating and sort within each group by title
const gamesByRating = new Map<string, typeof tierList.tier_list_games>();
for (const entry of tierList.tier_list_games ?? []) {
  const rating = entry.rating ?? "U";
  if (!gamesByRating.has(rating)) gamesByRating.set(rating, []);
  gamesByRating.get(rating)!.push(entry);
}
const tierGroups = Object.entries(TIER_RATING_CONFIG)
  .sort(([, a], [, b]) => a.sort - b.sort)
  .filter(([rating]) => gamesByRating.has(rating))
  .map(([rating, config]) => ({
    rating,
    color: config.color,
    displayLabel: config.displayLabel,
    games: (gamesByRating.get(rating) ?? []).sort((a, b) =>
      (a.game_id?.title || "").localeCompare(b.game_id?.title || "", undefined, { sensitivity: "base" })
    ),
  }));

const RAINBOW_GRAD = "linear-gradient(135deg,#ff5f6d,#ffc371,#fff45f,#6dff9a,#5fe2ff,#8c7bff,#ff6ddf)";
const RAINBOW_SHADOW = "0 0 0 1px rgba(255,255,255,.06),0 0 14px rgba(255,180,80,.22)";

const thumbBorderStyle = (reviewed, playerStatus, sTier, hasWalkthrough) => {
  const completed = playerStatus === "completed";
  const didNotFinish = playerStatus === "did_not_finish";
  const inProgress = playerStatus === "in_progress";
  const waitingForUpdate = playerStatus === "waiting_for_update";
  const statusColor = completed
    ? "#c0c0c0"
    : didNotFinish
      ? "#d14b4b"
      : inProgress
        ? "#70b7ff"
        : waitingForUpdate
          ? "#1f6b2b"
          : null;
  const innerBorderColor = hasWalkthrough
    ? "#8c58ff"
    : statusColor ?? (!reviewed && !sTier ? "#2b2b2b" : "transparent");
  const statusRingColor = hasWalkthrough ? statusColor : null;
  // Box-shadows have zero layout impact: all .tier-stack elements stay the same size
  // regardless of how many rings are active. Build from smallest spread (on top) outward.
  const shadows: string[] = [];
  let spread = 0;
  if (statusRingColor) {
    spread += 1; shadows.push(`0 0 0 ${spread}px #000`);
    spread += 2; shadows.push(`0 0 0 ${spread}px ${statusRingColor}`);
  }
  if (reviewed && (hasWalkthrough || statusColor)) {
    spread += 1; shadows.push(`0 0 0 ${spread}px #000`);
  }
  if (reviewed) {
    spread += 2; shadows.push(`0 0 0 ${spread}px #d3a43b`);
  }
  if (sTier && (reviewed || hasWalkthrough || statusColor)) {
    spread += 1; shadows.push(`0 0 0 ${spread}px #000`);
  }
  return [
    `--tier-rings:${shadows.length ? shadows.join(",") : "none"}`,
    `--ring-rainbow-bg:${sTier ? RAINBOW_GRAD : "transparent"}`,
    `--ring-rainbow-shadow:${sTier ? RAINBOW_SHADOW : "none"}`,
    `--rainbow-inset:${spread}px`,
    `--inner-border:${innerBorderColor}`,
  ].join(";");
};
---

<BaseLayout title={`Tier Lists | ${tierList.title}`} description={tierList.description ?? tierList.title}>
<main class="tier-page">
      <div class="tier-heading">
        <h1 class="tier-title">{tierList.title}</h1>
        <a class="csv-link" href={csvHref} download={csvName} aria-label="Download CSV">CSV</a>
      </div>
      {tierList.description && <p class="tier-desc">{tierList.description}</p>}

      <section class="tier-board" aria-label="Tier list">
        {tierGroups.map((group) => (
          <div class="tier-row">
            <div class="tier-label" style={`background:${group.color};`}>
              {group.displayLabel}
            </div>

            <div class="tier-cells">
              {group.games.length === 0 ? (
                <div class="tier-empty">No entries</div>
              ) : (
                group.games.map((entry) => {
                  const game = entry.game_id;
                  const img = fileUrl(game.cover_image);
                  const reviewed = reviewedGameIds.has(game.id);
                  const hasWalkthrough = walkthroughLinks(game?.links).length > 0;
                  const sTier = group.rating === "S";
                  return (
                    <div class="tier-stack" style={thumbBorderStyle(reviewed, game?.player_status, sTier, hasWalkthrough)}>
                      <a
                        class="tier-thumb"
                        href={`/games/${game.slug}/index.html`}
                        title={game.title}
                      >
                        <div class="tier-thumb-media">
                          {img ? (
                            <img src={img} alt={game.title} loading="lazy" />
                          ) : (
                            <span class="tier-thumb-fallback">No image</span>
                          )}
                        </div>
                        <div class="tier-thumb-title">{game.title}</div>
                      </a>
                    </div>
                  );
                })
              )}
            </div>
          </div>
        ))}
      </section>
      <ThumbnailBorderLegend style="margin-top:1rem;" />
    </main>
</BaseLayout>
