---
const base = (import.meta.env.ASSETS_BASE_URL ?? import.meta.env.ASSETS_URL ?? "").toString().replace(/\/$/, "");
const links = [
  { href: "/", label: "Home" },
  { href: "/about/index.html", label: "About" },
  { href: "/developers/index.html", label: "Devs" },
  { href: "/engines/index.html", label: "Engines" },
  { href: "/filters/index.html", label: "Filters" },
  { href: "/franchises/index.html", label: "Franchises" },
  { href: "/game_statuses/index.html", label: "Game Status" },
  { href: "/games/index.html", label: "Games" },
  { href: "/genres/index.html", label: "Genres" },
  { href: "/played_statuses/index.html", label: "Play Status" },
  { href: "/releases/index.html", label: "Releases" },
  { href: "/reviews/index.html", label: "Reviews" },
  { href: "/tiers/index.html", label: "Tiers" },
  { href: "/walkthroughs/index.html", label: "Guides" },
];
---

<header class="site-nav" data-pagefind-ignore>
  <nav class="site-nav__links">
    {links.map((link, index) => (
      <>
        {index > 0 ? <span class="site-nav__divider">|</span> : null}
        <a href={base ? `${base}${link.href}` : link.href}>{link.label}</a>
      </>
    ))}
  </nav>
  <div class="site-nav__search" id="search-container">
    <input
      type="search"
      id="search-input"
      class="search-input"
      placeholder="Search games…"
      autocomplete="off"
      aria-label="Search games"
      aria-haspopup="listbox"
      aria-expanded="false"
      spellcheck="false"
    />
    <div id="search-results" class="search-results" role="listbox" aria-label="Search results" hidden></div>
  </div>
</header>

<script is:inline>
  const container = document.getElementById('search-container');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  if (!container || !input || !results) throw new Error('Search elements missing');

  let pagefind;
  let debounceTimer;

  async function loadPagefind() {
    if (pagefind) return;
    try {
      pagefind = await import('/pagefind/pagefind.js');
    } catch {
      // Not available in dev mode — search is a build-time feature
    }
  }

  function hideResults() {
    results.hidden = true;
    results.innerHTML = '';
    input.setAttribute('aria-expanded', 'false');
  }

  function showResults(html) {
    results.innerHTML = html;
    results.hidden = false;
    input.setAttribute('aria-expanded', 'true');
  }

  async function runSearch() {
    if (!pagefind) return;
    const query = input.value.trim();
    if (!query) { hideResults(); return; }

    const res = await pagefind.search(query, { filters: { type: 'game' } });
    const top = await Promise.all(res.results.slice(0, 8).map((r) => r.data()));

    if (!top.length) {
      showResults('<div class="search-no-results">No results</div>');
      return;
    }

    const html = top.map((r) => `
      <a href="${r.url}" class="search-result-item">
        ${r.meta?.image
          ? `<img src="${r.meta.image}" alt="" class="search-result-img" />`
          : `<div class="search-result-img search-result-img--placeholder"></div>`}
        <span class="search-result-title">${r.meta?.title ?? ''}</span>
      </a>
    `).join('');
    showResults(html);
  }

  input.addEventListener('focus', loadPagefind, { once: true });
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(runSearch, 200);
  });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      hideResults();
      input.blur();
    }
  });
  document.addEventListener('click', (e) => {
    if (!container.contains(e.target)) hideResults();
  });
</script>

<style>
  /* Nav shell — two-column: links wrap freely, search pinned right */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #0d0d0d;
    border-bottom: 1px solid #1e1e1e;
    padding: 12px 24px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .site-nav__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    align-items: center;
    flex: 1 1 auto;
  }

  .site-nav__links a {
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    color: #9aa6ff;
    text-decoration: none;
  }

  .site-nav__divider {
    color: #5f667a;
    margin: 0 8px;
  }

  /* Search — pinned right, never wraps with the nav links */
  .site-nav__search {
    flex-shrink: 0;
    position: relative;
    padding-top: 3px;
  }

  .search-input {
    background: #1a1a2e;
    border: 1px solid #2a2a3a;
    border-radius: 6px;
    color: #eaeaea;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    font-size: 0.85rem;
    outline: none;
    padding: 5px 10px;
    width: 180px;
    transition: border-color 0.15s, width 0.2s;
  }

  .search-input:focus {
    border-color: #9aa6ff;
    width: 220px;
  }

  .search-input::placeholder {
    color: #5f667a;
  }

  .search-input::-webkit-search-cancel-button { display: none; }

  /* :global() so these apply to HTML injected via innerHTML in the script */
  :global(.search-results) {
    background: #0d0d0d;
    border: 1px solid #2a2a3a;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
    max-height: 400px;
    overflow-y: auto;
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    width: 300px;
    z-index: 100;
  }

  :global(.search-result-item) {
    align-items: center;
    color: #eaeaea;
    display: flex;
    gap: 10px;
    padding: 8px 12px;
    text-decoration: none;
    transition: background 0.1s;
  }

  :global(.search-result-item:hover),
  :global(.search-result-item:focus) {
    background: #1a1a2e;
    outline: none;
  }

  :global(.search-result-img) {
    border-radius: 3px;
    flex-shrink: 0;
    height: 28px;
    object-fit: cover;
    width: 28px;
  }

  :global(.search-result-img--placeholder) {
    background: #2a2a3a;
  }

  :global(.search-result-title) {
    font-size: 0.875rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-no-results) {
    color: #5f667a;
    font-size: 0.85rem;
    padding: 12px;
    text-align: center;
  }
</style>
